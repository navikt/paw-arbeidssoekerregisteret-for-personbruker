{
    "name": "paw-arbeidssoekerregisteret-for-personbruker",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.33.4",
    "scripts": {
        "dev": "next dev",
        "build": "next build --webpack",
        "start": "next start",
        "lint": "biome lint .",
        "test": "pnpm lint && vitest",
        "test:ci": "biome ci && vitest run",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build -o public/storybook",
        "test-storybook": "test-storybook",
        "refresh": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm i --ignore-scripts",
        "prepare": "husky"
    },
    "dependencies": {
        "@grafana/faro-web-sdk": "2.7.1",
        "@navikt/aksel-icons": "8.12.1",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.12.1",
        "@navikt/ds-react": "8.12.1",
        "@navikt/ds-tailwind": "8.12.1",
        "@navikt/nav-dekoratoren-moduler": "4.2.2",
        "@navikt/next-logger": "5.0.0",
        "@navikt/oasis": "4.1.4",
        "@unleash/nextjs": "1.6.4",
        "jose": "6.2.3",
        "next": "16.2.9",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "swr": "2.4.1",
        "uuid": "14.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.0",
        "@chromatic-com/storybook": "5.2.1",
        "@storybook/addon-a11y": "10.4.5",
        "@storybook/addon-docs": "10.4.5",
        "@storybook/addon-links": "10.4.5",
        "@storybook/addon-onboarding": "10.4.5",
        "@storybook/nextjs": "10.4.5",
        "@storybook/test-runner": "0.24.4",
        "@tailwindcss/postcss": "4.3.1",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/jest": "30.0.0",
        "@types/node": "25.9.3",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.2",
        "axe-playwright": "2.2.2",
        "concurrently": "10.0.3",
        "husky": "9.1.7",
        "jsdom": "29.1.1",
        "knip": "6.16.1",
        "lint-staged": "17.0.7",
        "msw": "2.14.6",
        "msw-storybook-addon": "2.0.7",
        "playwright": "1.61.0",
        "postcss": "8.5.15",
        "storybook": "10.4.5",
        "tailwindcss": "4.3.1",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vitest": "4.1.9"
    },
    "engines": {
        "node": ">=24.12.0"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    },
    "lint-staged": {
        "*.{ts,tsx,json,md,js,jsx}": [
            "biome check --write"
        ]
    },
    "pnpm": {
        "overrides": {
            "@babel/plugin-transform-modules-systemjs@>=7.12.0 <=7.29.3": ">=7.29.4",
            "axios@>=1.0.0 <1.15.2": ">=1.15.2",
            "fast-uri@<=3.1.1": ">=3.1.2",
            "follow-redirects@<=1.15.11": ">=1.16.0",
            "ip-address@<=10.1.0": ">=10.1.1",
            "js-cookie@<=3.0.5": ">=3.0.7",
            "postcss@<8.5.10": ">=8.5.10",
            "protobufjs@>=8.0.0 <=8.0.1": ">=8.0.2",
            "uuid@<11.1.1": ">=11.1.1",
            "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
            "ws@>=8.0.0 <8.20.1": ">=8.20.1",
            "qs@>=6.11.1 <=6.15.1": ">=6.15.2"
        }
    }
}
