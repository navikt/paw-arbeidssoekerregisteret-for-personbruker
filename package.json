{
    "name": "paw-arbeidssoekerregisteret-for-personbruker",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build --webpack",
        "start": "next start",
        "lint": "eslint",
        "test": "pnpm lint && vitest",
        "test:ci": "pnpm lint && vitest run",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build -o public/storybook",
        "test-storybook": "test-storybook",
        "refresh": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm i --ignore-scripts",
        "prepare": "husky"
    },
    "dependencies": {
        "@grafana/faro-web-sdk": "2.4.0",
        "@navikt/aksel-icons": "8.10.3",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.10.3",
        "@navikt/ds-react": "8.10.3",
        "@navikt/ds-tailwind": "8.10.3",
        "@navikt/nav-dekoratoren-moduler": "3.7.1",
        "@navikt/next-logger": "5.0.0",
        "@navikt/oasis": "4.1.4",
        "@unleash/nextjs": "1.6.4",
        "jose": "6.2.3",
        "next": "16.2.4",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "swr": "2.4.1",
        "uuid": "13.0.0"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "5.1.2",
        "@storybook/addon-a11y": "10.3.6",
        "@storybook/addon-docs": "10.3.6",
        "@storybook/addon-links": "10.3.6",
        "@storybook/addon-onboarding": "10.3.6",
        "@storybook/nextjs": "10.3.6",
        "@storybook/test-runner": "0.24.3",
        "@tailwindcss/postcss": "4.2.4",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/jest": "30.0.0",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.1.4",
        "axe-playwright": "2.2.2",
        "concurrently": "9.2.1",
        "eslint": "9.39.2",
        "eslint-config-next": "16.2.4",
        "husky": "9.1.7",
        "jsdom": "29.1.1",
        "knip": "6.11.0",
        "lint-staged": "16.4.0",
        "msw": "2.14.2",
        "msw-storybook-addon": "2.0.7",
        "playwright": "1.59.1",
        "postcss": "8.5.13",
        "prettier": "3.8.3",
        "storybook": "10.3.6",
        "tailwindcss": "4.2.4",
        "typescript": "6.0.3",
        "vitest": "4.1.5"
    },
    "prettier": {
        "printWidth": 120,
        "singleQuote": true,
        "tabWidth": 4
    },
    "engines": {
        "node": ">=24.12.0"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    },
    "lint-staged": {
        "*.{ts,tsx,json,md,js,jsx,md}": [
            "eslint --fix",
            "prettier --write"
        ]
    }
}
