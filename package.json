{
    "name": "paw-arbeidssoekerregisteret-for-personbruker",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@11.9.0",
    "scripts": {
        "dev": "next dev",
        "build": "next build --webpack",
        "start": "next start",
        "lint": "biome lint .",
        "test": "pnpm lint && vitest",
        "test:ci": "biome ci && vitest run",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build -o public/storybook",
        "test-storybook": "test-storybook",
        "refresh": "rm -rf node_modules && rm pnpm-lock.yaml && pnpm i --ignore-scripts",
        "prepare": "husky"
    },
    "dependencies": {
        "@grafana/faro-web-sdk": "2.8.0",
        "@navikt/aksel-icons": "8.14.0",
        "@navikt/arbeidssokerregisteret-utils": "2.1.0",
        "@navikt/ds-css": "8.14.0",
        "@navikt/ds-react": "8.14.0",
        "@navikt/ds-tailwind": "8.14.0",
        "@navikt/nav-dekoratoren-moduler": "4.2.2",
        "@navikt/next-logger": "5.0.0",
        "@navikt/oasis": "4.1.4",
        "@unleash/nextjs": "1.6.7",
        "jose": "6.2.3",
        "next": "16.2.9",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "swr": "2.4.2",
        "uuid": "14.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@chromatic-com/storybook": "5.2.1",
        "@storybook/addon-a11y": "10.4.6",
        "@storybook/addon-docs": "10.4.6",
        "@storybook/addon-links": "10.4.6",
        "@storybook/addon-onboarding": "10.4.6",
        "@storybook/nextjs": "10.4.6",
        "@storybook/test-runner": "0.24.4",
        "@tailwindcss/postcss": "4.3.1",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/jest": "30.0.0",
        "@types/node": "26.0.0",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.3",
        "axe-playwright": "2.2.2",
        "concurrently": "10.0.3",
        "husky": "9.1.7",
        "jsdom": "29.1.1",
        "knip": "6.23.0",
        "lint-staged": "17.0.8",
        "msw": "2.14.6",
        "msw-storybook-addon": "2.0.7",
        "playwright": "1.61.1",
        "postcss": "8.5.18",
        "storybook": "10.4.6",
        "tailwindcss": "4.3.1",
        "typescript": "6.0.3",
        "vite": "8.1.0",
        "vitest": "4.1.9"
    },
    "engines": {
        "node": ">=24.18.0"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    },
    "lint-staged": {
        "*.{ts,tsx,json,md,js,jsx}": [
            "biome check --write"
        ]
    }
}
